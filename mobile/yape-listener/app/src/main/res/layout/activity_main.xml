<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Yape Listener — prueba de conectividad"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/backendUrlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="URL del backend"
        android:text="http://192.168.100.82:3333"
        android:inputType="textUri" />

    <EditText
        android:id="@+id/apiKeyInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API key del dispositivo"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/saveConfigButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardar configuración"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/permissionStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="" />

    <Button
        android:id="@+id/openNotificationSettingsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activar acceso a notificaciones"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/batteryStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="" />

    <Button
        android:id="@+id/disableBatteryOptimizationButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Desactivar optimización de batería"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/sendEventButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviar evento de prueba (crudo)"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/simulateYapeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Simular notificación real de Yape"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text=""
        android:textIsSelectable="true" />

</LinearLayout>
