# Local (stack docker de docs/infrastructure/docker-compose.yml — puerto 54322, NO 5432):
# DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# Producción/hosted: connection string de tu Postgres
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"

# Fase 7 — NestJS emite y valida sus propios JWT. Generar con
# `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`,
# nunca reusar el mismo valor entre entornos.
JWT_SECRET="replace-me"
JWT_EXPIRES_IN="10h"

# Solo para Storage (Fase 5) — subida de imágenes de producto, se mantiene
# Supabase Storage como proveedor a propósito.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-me"

PORT=3333
FRONTEND_URL="http://localhost:3000"
