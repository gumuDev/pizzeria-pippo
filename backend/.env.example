# Local (stack docker de docs/infrastructure/docker-compose.yml — puerto 54322, NO 5432):
# DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"
# SUPABASE_JWT_SECRET="super-secret-jwt-token-for-local-dev-only"

# Producción/hosted: Supabase Dashboard > Settings > Database / API
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"
SUPABASE_JWT_SECRET="replace-me"

# Módulo de Usuarios — Admin API de Supabase Auth (crear/banear/borrar usuarios)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-me"

PORT=3333
FRONTEND_URL="http://localhost:3000"
