{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run build --workspace=@pippo/shared && node -e \"require('fs').copyFileSync(require.resolve('react-scan/dist/auto.global.js'), 'public/react-scan.js')\"",
    "dev": "next dev",
    "dev:prod": "dotenv -e .env.production -- next dev",
    "prebuild": "npm run build --workspace=@pippo/shared",
    "build": "next build",
    "build:local": "dotenv -e .env.local -- next build",
    "analyze": "ANALYZE=true dotenv -e .env.local -- next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@anthropic-ai/sdk": "^0.80.0",
    "@pippo/shared": "*",
    "@refinedev/antd": "^6.0.3",
    "@refinedev/core": "^5.0.9",
    "@refinedev/kbar": "^2.0.1",
    "@refinedev/nextjs-router": "^7.0.4",
    "@supabase/supabase-js": "^2.98.0",
    "antd": "^5.29.3",
    "next": "14.2.35",
    "next-intl": "^4.8.3",
    "next-pwa": "^5.6.0",
    "nextjs-toploader": "^3.9.17",
    "openai": "^6.32.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-bluetooth": "^0.0.21",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "react-scan": "^0.5.7",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
