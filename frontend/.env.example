# Fase 7 (migración NestJS) — el frontend ya no depende de Supabase para
# nada del negocio (Auth, datos, Storage vía backend). Estas 3 variables
# solo las usa el bot de Telegram con IA (chats autorizados + webhook),
# que quedó sin migrar a propósito por no estar en uso — ver memoria
# "Bot Telegram con IA no migrado". Si se retoma esa feature, migrarla
# a NestJS es el paso previo a poder borrar esto.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_VERSION=

# Backend NestJS
NEXT_PUBLIC_NEST_API_URL=http://localhost:3333
